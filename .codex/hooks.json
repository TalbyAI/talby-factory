{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "gentle-ai skill-registry refresh --quiet --no-gitignore --cwd \"$PWD\" || true",
            "statusMessage": "Refreshing skill registry",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ]
  }
}
