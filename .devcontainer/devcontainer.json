{
	"name": "talby-factory",
	"image": "mcr.microsoft.com/devcontainers/dotnet:2-10.0-noble",
	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
		"ghcr.io/devcontainers/features/node:2": {
			"version": "24.16.0",
			"pnpmVersion": "11.7.0",
			"nodeGypDependencies": true
		}
	},
	"remoteUser": "vscode",
	"remoteEnv": {
		"PATH": "${containerEnv:PATH}:/home/vscode/.dotnet/tools"
	},
	"mounts": [
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/vscode/.gitconfig-host,type=bind,readonly"
	],
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"tamasfe.even-better-toml",
				"github.copilot-chat",
				"ms-dotnettools.csdevkit",
				"ms-azuretools.vscode-docker",
				"github.vscode-pull-request-github",
				"ise-hve-essentials.hve-core-all"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash"
			}
		}
	}
}
