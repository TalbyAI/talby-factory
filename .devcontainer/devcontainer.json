{
	"name": "talby-factory",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
	},
	"mounts": [
		"source=talby-codex-home,target=/home/vscode/.codex,type=volume",
		"source=talby-copilot-home,target=/home/vscode/.copilot,type=volume",
		"source=talby-opencode-config-home,target=/home/vscode/.config/opencode,type=volume",
		"source=talby-opencode-share-home,target=/home/vscode/.local/share/opencode,type=volume",
		"source=talby-opencode-state-home,target=/home/vscode/.local/state/opencode,type=volume",
		"source=talby-opensrc-home,target=/home/vscode/.opensrc,type=volume",
		"source=talby-agents-skills-home,target=/home/vscode/.agents/skills,type=volume"
	],
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"postStartCommand": "bash .devcontainer/post-start.sh",
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"extensions": [
				"tamasfe.even-better-toml",
				"github.copilot-chat",
				"ms-dotnettools.csdevkit",
				"ms-azuretools.vscode-docker",
				"github.vscode-pull-request-github",
				"ise-hve-essentials.hve-core-all"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "bash"
			}
		}
	}
}
